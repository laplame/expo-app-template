{
  "name": "link4deal",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "postinstall": "patch-package",
    "version:bump": "node scripts/bump-version.js",
    "version:bump:patch": "node scripts/bump-version.js patch",
    "version:bump:minor": "node scripts/bump-version.js minor",
    "version:bump:major": "node scripts/bump-version.js major",
    "start": "expo start",
    "android": "expo run:android",
    "android:device": "expo run:android",
    "android:uninstall": "adb uninstall com.shatec.link4deal",
    "android:emulator": "sh -c 'if ! adb devices | grep -q emulator; then echo \"Iniciando emulador...\"; emulator -avd $(emulator -list-avds | head -n 1) > /dev/null 2>&1 & sleep 10; fi && expo run:android'",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:build:android": "eas build --platform android --profile production",
    "eas:build:android:preview": "eas build --platform android --profile preview",
    "eas:build:android:local": "eas build --platform android --profile production-apk --local",
    "apk:local": "bash build-apk.sh",
    "verify:auth-roles": "node scripts/verify-auth-roles.mjs"
  },
  "dependencies": {
    "@gluestack-style/react": "^1.0.57",
    "@gluestack-ui/config": "^1.1.20",
    "@gluestack-ui/themed": "^1.1.73",
    "@metamask/sdk-react-native": "^0.3.12",
    "@react-native-aria/focus": "^0.2.9",
    "@react-native-aria/interactions": "^0.2.16",
    "@react-native-aria/overlays": "^0.3.15",
    "@react-native-aria/utils": "^0.2.12",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/drawer": "^7.7.9",
    "@react-navigation/native": "^7.1.25",
    "@react-navigation/native-stack": "^7.8.6",
    "ethers": "^6.16.0",
    "expo": "~54.0.26",
    "expo-application": "^7.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-crypto": "^15.0.8",
    "expo-image-picker": "^17.0.9",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "^19.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.8",
    "expo-web-browser": "~15.0.8",
    "nostr-tools": "^2.23.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-drawer-layout": "^4.2.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-maps": "1.20.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.7.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.7",
    "patch-package": "^8.0.1",
    "react-refresh": "^0.18.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
