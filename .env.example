# ============================================
# Expo App Template - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================
# MongoDB Atlas / Backend API
# ============================================
# Backend API URL that connects to MongoDB Atlas (debe incluir /api al final)
# Production: https://www.damecodigo.com/api
# Local emulator: http://localhost:3000/api
# Local device físico: usa la IP de tu PC (ej. http://192.168.1.10:3000/api)
#   localhost en el dispositivo apunta al teléfono, no a tu PC
# IMPORTANTE: el backend debe tener MongoDB conectado. Si responde mode="simulated",
# la app rechazará la creación porque no hay persistencia real en BD.
EXPO_PUBLIC_API_URL=https://www.damecodigo.com/api

# Sitio web SPA (perfiles públicos /influencer/:slug). Producción: https://www.damecodigo.com
# Local web dev: http://localhost:5173
EXPO_PUBLIC_SITE_URL=https://www.damecodigo.com

# Panel del influencer (promos, deals, redenciones): /influencer/me
# Perfil público: /influencer/{publicSlug}

# ============================================
# Cloudinary Configuration
# ============================================
# Get these values from your Cloudinary dashboard:
# https://cloudinary.com/console

# Cloudinary Cloud Name (required)
# Found in: Dashboard > Account Details > Cloud name
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary API Key (required)
# Found in: Dashboard > Settings > Security > API Keys
EXPO_PUBLIC_CLOUDINARY_API_KEY=your_api_key

# Cloudinary API Secret (required for server-side uploads)
# Found in: Dashboard > Settings > Security > API Keys
# NOTE: For client-side uploads, use unsigned upload preset instead
EXPO_PUBLIC_CLOUDINARY_API_SECRET=your_api_secret

# Cloudinary Upload Preset (recommended for client-side uploads)
# Create in: Dashboard > Settings > Upload > Upload presets
# Set signing mode to "Unsigned" for client-side uploads
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Cloudinary Upload Folder (optional)
# Organize uploads in a specific folder
EXPO_PUBLIC_CLOUDINARY_UPLOAD_FOLDER=expo-app-uploads

# ============================================
# GPS / Location Services / Maps
# ============================================
# Google Maps API Key (para el mapa en Promociones)
# Obtener en: https://console.cloud.google.com/
# Habilitar: Maps SDK for Android, Maps SDK for iOS
google_maps=your_google_maps_api_key

# ============================================
# App Configuration
# ============================================
# App Environment
# Options: development, staging, production
EXPO_PUBLIC_APP_ENV=development

# App Version (optional)
EXPO_PUBLIC_APP_VERSION=1.0.0

# ============================================
# Feature Flags (optional)
# ============================================
# Enable/disable features
EXPO_PUBLIC_ENABLE_ANALYTICS=false

# Auth dev mode: permite login con cuentas de prueba (ver docs/APP_ROLE_AUTH_VERIFICATION.md)
EXPO_PUBLIC_AUTH_DEV_MODE=true
# ============================================
# BizneAI · cafés (catálogo público + preferencia programa 10 cafés)
# ============================================
# Lista GET JSON (por defecto la API pública de tiendas):
# https://bizneai.com/api/shop
EXPO_PUBLIC_BIZNEAI_SHOP_URL=https://bizneai.com/api/shop
# POST opcional: cuando el usuario elige o quita el café BizneAI preferido, el body incluye
# status: "selected" | "cleared", shopId, deviceId, programId: "link4deal_coffee_10_1", etc.
# Deja vacío si BizneAI aún no expone el endpoint.
EXPO_PUBLIC_BIZNEAI_CAFE_STATUS_POST_URL=
# Cafés extra (JSON array) si un local aún no aparece en GET /api/shop. Ejemplo «Olas de café»:
# EXPO_PUBLIC_BIZNEAI_CAFE_SUPPLEMENT_JSON=[{"id":"olas-de-cafe","storeName":"Olas de café","storeType":"CoffeeShop","status":"active","luxaeEnabled":true,"kitchenEnabled":true,"fullAddress":"..."}]
EXPO_PUBLIC_BIZNEAI_CAFE_SUPPLEMENT_JSON=

